{
  "manifest_version": 3,
  "name": "CarDekho Scraper",
  "version": "2.0",
  "description": "Scrape used car listings from any CarDekho city page. Auto-detects pages. Export as JSON/CSV.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "https://www.cardekho.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}